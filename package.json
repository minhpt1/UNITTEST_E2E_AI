{
  "name": "personal-blog",
  "version": "1.0.0",
  "description": "A simple personal blog with TypeScript and JSON database",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "start:all": "concurrently \"npm run dev\" \"cd client && npm start\"",
    "start:dev": "concurrently \"npm run dev\" \"cd client && npm start\"",
    "install:all": "npm install && cd client && npm install",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run"
  },
  "keywords": [
    "blog",
    "typescript",
    "express",
    "personal"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0",
    "vitest": "^2.1.8"
  }
}
